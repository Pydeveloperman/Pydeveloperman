{
  "name": "NotificationLog",
  "type": "object",
  "properties": {
    "prayer_name": {
      "type": "string",
      "description": "Namoz nomi (Fajr, Dhuhr, ...)"
    },
    "prayer_label": {
      "type": "string",
      "description": "Namoz o'zbekcha nomi"
    },
    "sent_at": {
      "type": "string",
      "format": "date-time",
      "description": "Yuborilgan vaqt"
    }
  },
  "required": [
    "prayer_name",
    "prayer_label"
  ]
}