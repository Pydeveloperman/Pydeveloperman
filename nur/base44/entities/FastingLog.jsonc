{
  "name": "FastingLog",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "fasted",
        "missed"
      ],
      "default": "fasted"
    }
  },
  "required": [
    "date"
  ]
}